generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["opod"]
}

enum MediaType {
  image
  video

  @@map("media_type")
  @@schema("opod")
}

enum PostContentType {
  feed
  reel

  @@map("post_content_type")
  @@schema("opod")
}

enum MessageSenderType {
  user
  character

  @@map("message_sender_type")
  @@schema("opod")
}

enum CreditEntryType {
  grant
  debit

  @@map("credit_entry_type")
  @@schema("opod")
}

enum CreditPurchaseStatus {
  pending
  paid
  failed
  canceled
  refunded

  @@map("credit_purchase_status")
  @@schema("opod")
}

enum CreditReservationStatus {
  reserved
  captured
  released

  @@map("credit_reservation_status")
  @@schema("opod")
}

enum GenerationJobStatus {
  draft
  queued
  running
  completed
  failed

  @@map("generation_job_status")
  @@schema("opod")
}

// docs/media-generation-pipeline.md 상태 머신. needs_review = arch doc의 review.
enum PostDraftStatus {
  planned
  generating
  needs_review
  regenerating
  approved
  rejected
  published
  failed

  @@map("post_draft_status")
  @@schema("opod")
}

enum PostDraftType {
  post
  story

  @@map("post_draft_type")
  @@schema("opod")
}

enum ReportTargetType {
  character
  post
  message

  @@map("report_target_type")
  @@schema("opod")
}

enum ReportStatus {
  submitted
  reviewing
  resolved
  rejected

  @@map("report_status")
  @@schema("opod")
}

enum CharacterStatus {
  active
  inactive

  @@map("character_status")
  @@schema("opod")
}

enum InquiryStatus {
  submitted
  answered

  @@map("inquiry_status")
  @@schema("opod")
}

model User {
  id                   String                  @id @default(uuid(7)) @db.Uuid
  email                String?                 @unique
  passwordHash         String?                 @map("password_hash")
  passwordSalt         String?                 @map("password_salt")
  displayName          String                  @map("display_name")
  bio                  String                  @default("")
  profileImageUrl      String?                 @map("profile_image_url")
  createdAt            DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime                @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt            DateTime?               @map("deleted_at") @db.Timestamptz(6)
  characterFollows     UserCharacterFollow[]
  creditCheckIns       CreditCheckIn[]
  creditLedgerEntries  CreditLedgerEntry[]
  creditPurchases      CreditPurchase[]
  creditReservations   CreditReservation[]
  events               UserEvent[]
  inquiries            Inquiry[]
  messageConversations MessageConversation[]
  notifications        Notification[]
  postComments         PostComment[]
  postReactions        PostReaction[]
  refreshTokens        UserRefreshToken[]
  reports              Report[]
  hashtagPreferences   UserHashtagPreference[]

  @@map("users")
  @@schema("opod")
}

model UserRefreshToken {
  id        String    @id @default(uuid(7)) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("user_refresh_tokens")
  @@schema("opod")
}

model UserWithdrawal {
  id             String   @id @default(uuid(7)) @db.Uuid
  // 익명화된 users 행을 느슨하게 가리키는 평문 uuid (FK 없음).
  userId         String   @map("user_id") @db.Uuid
  reasonCategory String?  @map("reason_category")
  reasonText     String?  @map("reason_text")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("user_withdrawals")
  @@schema("opod")
}

model Faq {
  id          String   @id @default(uuid(7)) @db.Uuid
  category    String
  question    String
  answer      String
  sortOrder   Int      @default(0) @map("sort_order")
  isPublished Boolean  @default(false) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([isPublished, category, sortOrder])
  @@map("faqs")
  @@schema("opod")
}

model Notice {
  id          String    @id @default(uuid(7)) @db.Uuid
  title       String
  body        String
  isPinned    Boolean   @default(false) @map("is_pinned")
  // null = 초안, 미래 시각 = 예약 발행. 발행분만 서비스에 노출된다.
  publishedAt DateTime? @map("published_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([isPinned, publishedAt])
  @@map("notices")
  @@schema("opod")
}

model Inquiry {
  id         String        @id @default(uuid(7)) @db.Uuid
  // 탈퇴 후에도 익명화된 users 행에 연결을 유지한다 (분쟁처리 기록 보존).
  userId     String        @map("user_id") @db.Uuid
  category   String
  body       String
  status     InquiryStatus @default(submitted)
  // 답변은 opod-admin이 기록한다. 답변 저장 시 inquiry.answered 알림 계약 참조.
  answerBody String?       @map("answer_body")
  answeredAt DateTime?     @map("answered_at") @db.Timestamptz(6)
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  user       User          @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@map("inquiries")
  @@schema("opod")
}

// 운영 콘솔에서 관리하는 키-값 설정 (예: 생성 프로바이더 API 키/모델).
// 쓰기는 opod-admin만 수행한다. 값은 평문 저장이므로 노출 API는 반드시 마스킹한다.
model AdminSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("admin_settings")
  @@schema("opod")
}

model Admin {
  id        String   @id @default(uuid(7)) @db.Uuid
  email     String   @unique
  password  String
  isEnabled Boolean  @default(true) @map("is_enabled")
  isDeleted Boolean  @default(false) @map("is_deleted")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([isEnabled, isDeleted])
  @@map("admins")
  @@schema("opod")
}

model Character {
  id             String                  @id @default(uuid(7)) @db.Uuid
  publicId       String                  @unique @map("public_id")
  displayName    String                  @map("display_name")
  bio            String
  interests      String[]                @default([])
  status         CharacterStatus         @default(active)
  createdAt      DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  actionLogs     CharacterActionLog[]
  comments       PostComment[]
  conversations  MessageConversation[]
  generationJobs GenerationJob[]
  memories       CharacterMemory[]
  personas       CharacterPersona[]
  posts          Post[]
  reactions      PostReaction[]
  stories        Story[]
  userFollowers  UserCharacterFollow[]
  visualProfile  CharacterVisualProfile?
  postDrafts     PostDraft[]
  postingPolicy  CharacterPostingPolicy?

  @@map("characters")
  @@schema("opod")
}

model UserCharacterFollow {
  userId      String    @map("user_id") @db.Uuid
  characterId String    @map("character_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user        User      @relation(fields: [userId], references: [id])
  character   Character @relation(fields: [characterId], references: [id])

  @@id([userId, characterId])
  @@map("user_character_follows")
  @@schema("opod")
}

model Media {
  id                      String                            @id @default(uuid(7)) @db.Uuid
  mediaType               MediaType                         @map("media_type")
  url                     String
  storageKey              String?                           @unique @map("storage_key")
  contentType             String?                           @map("content_type")
  byteSize                Int?                              @map("byte_size")
  width                   Int?
  height                  Int?
  durationSeconds         Int?                              @map("duration_seconds")
  // AI 기본법 합성콘텐츠 표시 의무 근거 플래그. 워커가 생성한 미디어는 항상 true.
  isAiGenerated           Boolean                           @default(false) @map("is_ai_generated")
  uploadedAt              DateTime?                         @map("uploaded_at") @db.Timestamptz(6)
  createdAt               DateTime                          @default(now()) @map("created_at") @db.Timestamptz(6)
  generationJobs          GenerationJob[]
  jobOutputs              GenerationJobOutput[]
  postMedia               PostMedia[]
  stories                 Story[]
  visualProfileReferences CharacterVisualProfileReference[]

  @@map("media")
  @@schema("opod")
}

model Post {
  id           String          @id @default(uuid(7)) @db.Uuid
  characterId  String          @map("character_id") @db.Uuid
  character    Character       @relation(fields: [characterId], references: [id])
  contentType  PostContentType @default(feed) @map("content_type")
  content      String          @default("")
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  comments     PostComment[]
  hashtags     PostHashtag[]
  postMedia    PostMedia[]
  reactions    PostReaction[]
  sourceDrafts PostDraft[]

  @@map("posts")
  @@schema("opod")
}

model Hashtag {
  id          String                  @id @default(uuid(7)) @db.Uuid
  name        String                  @unique
  createdAt   DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  posts       PostHashtag[]
  preferences UserHashtagPreference[]

  @@map("hashtags")
  @@schema("opod")
}

model PostHashtag {
  postId    String  @map("post_id") @db.Uuid
  hashtagId String  @map("hashtag_id") @db.Uuid
  post      Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  hashtag   Hashtag @relation(fields: [hashtagId], references: [id], onDelete: Cascade)

  @@id([postId, hashtagId])
  @@index([hashtagId])
  @@map("post_hashtags")
  @@schema("opod")
}

model PostMedia {
  postId    String @map("post_id") @db.Uuid
  mediaId   String @map("media_id") @db.Uuid
  sortOrder Int    @default(0) @map("sort_order")
  post      Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  media     Media  @relation(fields: [mediaId], references: [id])

  @@id([postId, mediaId])
  @@map("post_media")
  @@schema("opod")
}

model Story {
  id           String      @id @default(uuid(7)) @db.Uuid
  characterId  String      @map("character_id") @db.Uuid
  mediaId      String      @map("media_id") @db.Uuid
  caption      String      @default("")
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt    DateTime    @map("expires_at") @db.Timestamptz(6)
  character    Character   @relation(fields: [characterId], references: [id], onDelete: Cascade)
  media        Media       @relation(fields: [mediaId], references: [id])
  sourceDrafts PostDraft[]

  @@index([expiresAt, createdAt])
  @@index([characterId, expiresAt, createdAt])
  @@map("stories")
  @@schema("opod")
}

model PostComment {
  id          String     @id @default(uuid(7)) @db.Uuid
  postId      String     @map("post_id") @db.Uuid
  characterId String?    @map("character_id") @db.Uuid
  userId      String?    @map("user_id") @db.Uuid
  body        String
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  post        Post       @relation(fields: [postId], references: [id], onDelete: Cascade)
  character   Character? @relation(fields: [characterId], references: [id])
  user        User?      @relation(fields: [userId], references: [id])

  @@index([postId, createdAt])
  @@index([characterId, createdAt])
  @@index([userId, createdAt])
  @@map("post_comments")
  @@schema("opod")
}

model PostReaction {
  id           String     @id @default(uuid(7)) @db.Uuid
  postId       String     @map("post_id") @db.Uuid
  characterId  String?    @map("character_id") @db.Uuid
  userId       String?    @map("user_id") @db.Uuid
  reactionType String     @map("reaction_type")
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  post         Post       @relation(fields: [postId], references: [id], onDelete: Cascade)
  character    Character? @relation(fields: [characterId], references: [id])
  user         User?      @relation(fields: [userId], references: [id])

  @@unique([postId, userId, reactionType])
  @@index([postId, createdAt])
  @@index([characterId, createdAt])
  @@index([userId, createdAt])
  @@map("post_reactions")
  @@schema("opod")
}

model UserEvent {
  id         String   @id @default(uuid(7)) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  eventType  String   @map("event_type")
  targetType String   @map("target_type")
  targetId   String   @map("target_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([targetType, targetId])
  @@map("user_events")
  @@schema("opod")
}

model UserHashtagPreference {
  userId    String   @map("user_id") @db.Uuid
  hashtagId String   @map("hashtag_id") @db.Uuid
  score     Float    @default(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  hashtag   Hashtag  @relation(fields: [hashtagId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@id([userId, hashtagId])
  @@index([hashtagId])
  @@map("user_hashtag_preferences")
  @@schema("opod")
}

model Notification {
  id         String    @id @default(uuid(7)) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  type       String
  title      String
  body       String?
  targetType String?   @map("target_type")
  targetId   String?   @map("target_id") @db.Uuid
  readAt     DateTime? @map("read_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@index([userId, createdAt])
  @@map("notifications")
  @@schema("opod")
}

model MessageConversation {
  id          String    @id @default(uuid(7)) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  characterId String    @map("character_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user        User      @relation(fields: [userId], references: [id])
  character   Character @relation(fields: [characterId], references: [id])
  messages    Message[]

  @@unique([userId, characterId])
  @@map("message_conversations")
  @@schema("opod")
}

model Message {
  id             String              @id @default(uuid(7)) @db.Uuid
  conversationId String              @map("conversation_id") @db.Uuid
  senderType     MessageSenderType   @map("sender_type")
  body           String
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  conversation   MessageConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
  @@schema("opod")
}

model CreditLedgerEntry {
  id                String          @id @default(uuid(7)) @db.Uuid
  userId            String          @map("user_id") @db.Uuid
  entryType         CreditEntryType @map("entry_type")
  amount            Int
  // grant-only: unconsumed credits left in this grant bucket.
  remainingAmount   Int?            @map("remaining_amount")
  // grant-only: free credits expire; null means no expiry (paid credits).
  expiresAt         DateTime?       @map("expires_at") @db.Timestamptz(6)
  reason            String
  externalReference String?         @map("external_reference")
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  user              User            @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([userId, entryType, expiresAt])
  @@map("credit_ledger_entries")
  @@schema("opod")
}

model CreditPurchase {
  id           String               @id @default(uuid(7)) @db.Uuid
  userId       String               @map("user_id") @db.Uuid
  provider     String
  status       CreditPurchaseStatus @default(pending)
  creditAmount Int                  @map("credit_amount")
  paidAmount   Int                  @map("paid_amount")
  currency     String               @default("KRW")
  createdAt    DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  user         User                 @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@map("credit_purchases")
  @@schema("opod")
}

model CreditReservation {
  id         String                  @id @default(uuid(7)) @db.Uuid
  userId     String                  @map("user_id") @db.Uuid
  actionType String                  @map("action_type")
  amount     Int
  status     CreditReservationStatus @default(reserved)
  reference  String                  @unique
  expiresAt  DateTime                @map("expires_at") @db.Timestamptz(6)
  createdAt  DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  user       User                    @relation(fields: [userId], references: [id])

  @@index([userId, status, expiresAt])
  @@map("credit_reservations")
  @@schema("opod")
}

model CreditCheckIn {
  id          String   @id @default(uuid(7)) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  // KST calendar date the user checked in, formatted YYYY-MM-DD.
  checkInDate String   @map("check_in_date")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user        User     @relation(fields: [userId], references: [id])

  @@unique([userId, checkInDate])
  @@map("credit_check_ins")
  @@schema("opod")
}

model GenerationJob {
  id                String                @id @default(uuid(7)) @db.Uuid
  characterId       String                @map("character_id") @db.Uuid
  mediaType         MediaType             @map("media_type")
  prompt            String
  inputPrompt       String?               @map("input_prompt")
  candidateCount    Int?                  @map("candidate_count")
  status            GenerationJobStatus   @default(queued)
  // 선택된 최종 출력 캐시. 후보 전체는 GenerationJobOutput에 기록된다.
  outputMediaId     String?               @map("output_media_id") @db.Uuid
  provider          String?
  paramsJson        Json?                 @map("params_json")
  // 프로바이더 제출 직후 기록. 재시작/재수용 시 새로 제출하지 않고 결과 폴링으로
  // 이어받는 근거이자 이중 제출·이중 과금 방지 장치.
  providerRequestId String?               @map("provider_request_id")
  // 워커 claim 시 설정. 만료된 running 잡은 스윕이 queued로 되돌리거나 failed 처리.
  leaseExpiresAt    DateTime?             @map("lease_expires_at") @db.Timestamptz(6)
  attemptCount      Int                   @default(0) @map("attempt_count")
  // 수동 재생성 계보. 자동 재시도는 같은 행의 attemptCount 증가로 처리한다.
  originJobId       String?               @map("origin_job_id") @db.Uuid
  errorMessage      String?               @map("error_message")
  costUsd           Decimal?              @map("cost_usd") @db.Decimal(10, 4)
  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  // draft 소속 컷. draft 1 : 컷 N (sortOrder = 캐러셀 순서). 수동 재생성 시
  // 같은 (draftId, sortOrder)로 새 행이 생기며, 집계는 컷별 최신 행 기준.
  draftId           String?               @map("draft_id") @db.Uuid
  sortOrder         Int                   @default(0) @map("sort_order")
  character         Character             @relation(fields: [characterId], references: [id])
  outputMedia       Media?                @relation(fields: [outputMediaId], references: [id])
  originJob         GenerationJob?        @relation("GenerationJobRetries", fields: [originJobId], references: [id])
  retries           GenerationJob[]       @relation("GenerationJobRetries")
  outputs           GenerationJobOutput[]
  draft             PostDraft?            @relation(fields: [draftId], references: [id])

  @@index([status, createdAt])
  @@index([status, leaseExpiresAt])
  @@index([draftId])
  @@map("generation_jobs")
  @@schema("opod")
}

// 포스트 초안 — 기획~게시의 단위이자 워커의 기획/게시 큐.
model PostDraft {
  id               String          @id @default(uuid(7)) @db.Uuid
  characterId      String          @map("character_id") @db.Uuid
  draftType        PostDraftType   @default(post) @map("draft_type")
  contentType      PostContentType @default(feed) @map("content_type")
  caption          String          @default("")
  hashtags         String[]        @default([])
  // LLM 기획 원본 (shots 포함). 수동 생성 시 scene 힌트도 여기 담는다.
  conceptJson      Json?           @map("concept_json")
  status           PostDraftStatus @default(planned)
  errorMessage     String?         @map("error_message")
  // 워커 claim lease. 만료된 generating 잡은 스윕이 회수한다.
  leaseExpiresAt   DateTime?       @map("lease_expires_at") @db.Timestamptz(6)
  attemptCount     Int             @default(0) @map("attempt_count")
  // 게시 예정 시각 (KST 정책으로 산출, UTC 저장). null이면 승인 즉시 게시.
  scheduledAt      DateTime?       @map("scheduled_at") @db.Timestamptz(6)
  publishedPostId  String?         @map("published_post_id") @db.Uuid
  publishedStoryId String?         @map("published_story_id") @db.Uuid
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  character        Character       @relation(fields: [characterId], references: [id])
  publishedPost    Post?           @relation(fields: [publishedPostId], references: [id])
  publishedStory   Story?          @relation(fields: [publishedStoryId], references: [id])
  jobs             GenerationJob[]

  @@index([status, scheduledAt])
  @@index([status, leaseExpiresAt])
  @@index([characterId, createdAt])
  @@map("post_drafts")
  @@schema("opod")
}

// 캐릭터별 자동 포스팅 정책. 스케줄러가 이 정책으로 planned draft를 생성한다.
model CharacterPostingPolicy {
  id            String    @id @default(uuid(7)) @db.Uuid
  characterId   String    @unique @map("character_id") @db.Uuid
  enabled       Boolean   @default(false)
  // 주당 게시 횟수. 게시 간격 = 7/weeklyCadence일.
  weeklyCadence Int       @default(3) @map("weekly_cadence")
  // 게시 시간창 (KST 시, 0-23). 창 내 랜덤 지터로 scheduledAt을 잡는다.
  hourStartKst  Int       @default(18) @map("hour_start_kst")
  hourEndKst    Int       @default(22) @map("hour_end_kst")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  character     Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@map("character_posting_policies")
  @@schema("opod")
}

// best-of-N 후보 저장. 잡 1개 = 컷 1개, 후보 이미지들이 candidateIndex로 매달린다.
model GenerationJobOutput {
  id             String        @id @default(uuid(7)) @db.Uuid
  jobId          String        @map("job_id") @db.Uuid
  mediaId        String        @map("media_id") @db.Uuid
  candidateIndex Int           @map("candidate_index")
  selected       Boolean       @default(false)
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  job            GenerationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  media          Media         @relation(fields: [mediaId], references: [id])

  @@unique([jobId, candidateIndex])
  @@index([mediaId])
  @@map("generation_job_outputs")
  @@schema("opod")
}

// 캐릭터의 시각적 정체성. 페르소나(말투/성격)와 분리된 외모/화풍 프롬프트와
// 레퍼런스 이미지 세트. 미디어 생성 프롬프트 컴파일 시 주입된다.
model CharacterVisualProfile {
  id               String                            @id @default(uuid(7)) @db.Uuid
  characterId      String                            @unique @map("character_id") @db.Uuid
  appearancePrompt String                            @default("") @map("appearance_prompt")
  stylePrompt      String                            @default("") @map("style_prompt")
  negativePrompt   String                            @default("") @map("negative_prompt")
  providerConfig   Json?                             @map("provider_config")
  createdAt        DateTime                          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime                          @updatedAt @map("updated_at") @db.Timestamptz(6)
  character        Character                         @relation(fields: [characterId], references: [id], onDelete: Cascade)
  referenceMedia   CharacterVisualProfileReference[]

  @@map("character_visual_profiles")
  @@schema("opod")
}

model CharacterVisualProfileReference {
  profileId   String                 @map("profile_id") @db.Uuid
  mediaId     String                 @map("media_id") @db.Uuid
  sortOrder   Int                    @default(0) @map("sort_order")
  // 비전 LLM이 생성한 이미지 서술(장면·구도·의상·조명) — 기획 LLM이 샷별로
  // 관련 레퍼런스를 선별하는 데 쓴다. 빈 값은 캡셔닝 전(백필 대상).
  description String                 @default("")
  profile     CharacterVisualProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  media       Media                  @relation(fields: [mediaId], references: [id])

  @@id([profileId, mediaId])
  @@map("character_visual_profile_references")
  @@schema("opod")
}

model CharacterActionLog {
  id          BigInt    @id @default(autoincrement())
  characterId String    @map("character_id") @db.Uuid
  actionType  String    @map("action_type")
  targetTable String?   @map("target_table")
  targetId    String?   @map("target_id") @db.Uuid
  reason      String
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  character   Character @relation(fields: [characterId], references: [id])

  @@index([characterId, createdAt])
  @@map("character_action_logs")
  @@schema("opod")
}

model Report {
  id             String           @id @default(uuid(7)) @db.Uuid
  reporterUserId String           @map("reporter_user_id") @db.Uuid
  targetType     ReportTargetType @map("target_type")
  targetId       String           @map("target_id") @db.Uuid
  reason         String
  details        String?
  resolution     String?
  status         ReportStatus     @default(submitted)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  reporterUser   User             @relation(fields: [reporterUserId], references: [id])

  @@index([status, createdAt])
  @@index([targetType, targetId])
  @@map("reports")
  @@schema("opod")
}

model CharacterMemory {
  id          String    @id @default(uuid(7)) @db.Uuid
  characterId String    @map("character_id") @db.Uuid
  content     String
  reason      String
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId, deletedAt, createdAt])
  @@map("character_memories")
  @@schema("opod")
}

model CharacterPersona {
  id          String    @id @default(uuid(7)) @db.Uuid
  characterId String    @map("character_id") @db.Uuid
  title       String
  content     String
  // Assembly order when personas are stitched into a prompt; lower comes first.
  // Assigned in steps of 10 so entries can be inserted between without renumber.
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId, deletedAt, sortOrder])
  @@map("character_personas")
  @@schema("opod")
}

// ── Agent relationship memory (opod-agent owned; hosted here as schema owner) ──
// The Agent reads/writes these directly (opod-agent docs/persona-memory-plan.md,
// its ADR-0002/0005). Ids are TEXT on purpose: identity arrives via X-Opod-*
// headers and is not guaranteed to reference opod rows, so no FKs — deleting a
// user must explicitly delete their agent_* rows (withdrawal flow).

enum AgentMemoryKind {
  observation
  reflection

  @@map("agent_memory_kind")
  @@schema("opod")
}

enum AgentJobStatus {
  queued
  running
  completed
  failed

  @@map("agent_job_status")
  @@schema("opod")
}

// Append-only observation/reflection stream per (user, character) relationship.
// Embeddings stay double precision[]; ranking runs in the Agent (pgvector is
// deferred until relationship volume warrants it — same observe-then-adopt rule
// as the content pipeline).
model AgentArchivalMemory {
  id             String          @id @default(uuid(7)) @db.Uuid
  userId         String          @map("user_id")
  characterId    String          @map("character_id")
  content        String
  kind           AgentMemoryKind
  importance     Float
  embedding      Float[]
  // For reflections: ids of the memories this was inferred from.
  evidence       String[]        @default([])
  // Idempotent batch writes: (relationship, operation, ordinal) is unique so a
  // retried consolidation returns the original rows instead of inserting again.
  operationKey   String?         @map("operation_key")
  ordinal        Int             @default(0)
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  lastAccessedAt DateTime        @default(now()) @map("last_accessed_at") @db.Timestamptz(6)

  @@unique([userId, characterId, operationKey, ordinal])
  @@index([userId, characterId, lastAccessedAt])
  @@index([userId, characterId, kind, createdAt])
  @@map("agent_archival_memories")
  @@schema("opod")
}

// MemGPT-style always-injected relationship digest, self-rewritten on reflection.
model AgentCoreMemory {
  userId      String   @map("user_id")
  characterId String   @map("character_id")
  content     String
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@id([userId, characterId])
  @@map("agent_core_memories")
  @@schema("opod")
}

// Reflection-trigger accumulator; consumed atomically (UPDATE … RETURNING).
model AgentRelationshipState {
  userId                    String   @map("user_id")
  characterId               String   @map("character_id")
  importanceSinceReflection Float    @default(0) @map("importance_since_reflection")
  updatedAt                 DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@id([userId, characterId])
  @@map("agent_relationship_state")
  @@schema("opod")
}

// Rolling session summary; revision is a compare-and-swap guard.
model AgentSummary {
  userId       String   @map("user_id")
  characterId  String   @map("character_id")
  sessionId    String   @map("session_id")
  content      String
  turnsCovered Int      @map("turns_covered")
  revision     Int
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@id([userId, characterId, sessionId])
  @@map("agent_summaries")
  @@schema("opod")
}

// Applied-operation ledger backing idempotent core/importance/summary writes.
model AgentMemoryOperation {
  id           String   @id @default(uuid(7)) @db.Uuid
  userId       String   @map("user_id")
  characterId  String   @map("character_id")
  operationKey String   @map("operation_key")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([userId, characterId, operationKey])
  @@map("agent_memory_operations")
  @@schema("opod")
}

// Durable queue for consolidation ("memory-update") jobs; claimed with
// FOR UPDATE SKIP LOCKED like the admin generation queue. The relationship
// identity is promoted out of payload_json so the worker can serialize
// execution per (user, character) and withdrawal cleanup can target a user.
model AgentMemoryJob {
  id             String         @id @default(uuid(7)) @db.Uuid
  idempotencyKey String         @unique @map("idempotency_key")
  userId         String         @map("user_id")
  characterId    String         @map("character_id")
  payloadJson    Json           @map("payload_json")
  status         AgentJobStatus @default(queued)
  attemptCount   Int            @default(0) @map("attempt_count")
  leaseExpiresAt DateTime?      @map("lease_expires_at") @db.Timestamptz(6)
  errorMessage   String?        @map("error_message")
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([status, leaseExpiresAt])
  @@index([userId, characterId, status])
  @@map("agent_memory_jobs")
  @@schema("opod")
}

// 콘솔(관리자)에서 수행된 행위의 감사 로그 — 설정 변경 등. 캐릭터 스코프
// 액션은 CharacterActionLog가 담당하고, 여기는 캐릭터와 무관한 콘솔 행위.
model ConsoleLog {
  id         BigInt   @id @default(autoincrement())
  // 관리자 식별 — 계정 삭제 후에도 이력이 읽히도록 FK 없이 스냅샷.
  adminId    String?  @map("admin_id") @db.Uuid
  adminEmail String?  @map("admin_email")
  actionType String   @map("action_type")
  target     String?
  // 민감 값은 요약만 — API 키는 last4, 원문 금지.
  summary    String
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([createdAt])
  @@index([actionType, createdAt])
  @@map("console_logs")
  @@schema("opod")
}

// 서비스/워커(시스템)에서 발생한 이벤트 로그 — 사람 행위는 console_logs.
model ServiceLog {
  id          BigInt   @id @default(autoincrement())
  source      String
  level       String   @default("info")
  eventType   String   @map("event_type")
  message     String
  contextJson Json?    @map("context_json")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([createdAt])
  @@index([eventType, createdAt])
  @@map("service_logs")
  @@schema("opod")
}
